# Production template — kopyalayın: SUNUCUDA `/.env.production` olarak (chmod 600). Geliştirici makinesinde
# tutmak zorunlu değildir; `pnpm push:vps` varsa doğrulama için kullanılabilir.
# Never commit real `.env.production` values.

NODE_ENV=production

# Docker image registry / tag.
# GitHub Actions passes the immutable deploy SHA as IMAGE_TAG at runtime; keep this fallback on the moving main alias.
REGISTRY=ghcr.io/your-github-owner
REGISTRY_SERVER=ghcr.io
REGISTRY_USERNAME=your-github-username
REGISTRY_PASSWORD=change_me_read_packages_token
IMAGE_TAG=main

# Host Nginx uyumu: vitrin için Docker’ın yayınladığı loopback portu (VPS varsayılan 3000).
# WEB_PROD_HOST_WEB_PORT=3050

# Application
API_PORT=3003
# Browser-facing API URL
API_URL=https://api.azem.cloud
PUBLIC_API_URL=https://api.azem.cloud
NEXT_PUBLIC_API_URL=https://api.azem.cloud
CORS_ORIGINS=https://www.azem.cloud,https://admin.azem.cloud,https://courier.azem.cloud
# Server-side Next.js BFF calls inside Docker default to service name:
# WEB_API_URL=http://api:3003
WEB_API_URL=http://api:3003
ADMIN_API_URL=http://api:3003
COURIER_API_URL=http://api:3003
RUNNING_IN_DOCKER=1
SWAGGER_ENABLED=false

# PostgreSQL — production DB is the supabase-prod stack (`supabase-db` service).
# Legacy `postgres` profile removed after Faz 7.2 closeout (volume may still exist on VPS).
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_DB=pastane_db
POSTGRES_USER=pastane_user
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql://pastane_user:change_me_strong@supabase-db:5432/pastane_db
# Same host as DATABASE_URL until pgBouncer enabled; required for prisma migrate deploy.
DIRECT_URL=postgresql://pastane_user:change_me_strong@supabase-db:5432/pastane_db

# Supabase self-hosted stack (Faz 8.0) — https://studio.azem.cloud
# Generate secrets once: bash scripts/generate-supabase-secrets.sh
SUPABASE_STUDIO_ENABLED=1
SUPABASE_PUBLIC_URL=https://studio.azem.cloud
DASHBOARD_USERNAME=studio-admin
DASHBOARD_PASSWORD=change_me_dashboard_strong_min_20_chars
SUPABASE_JWT_SECRET=change_me_supabase_jwt_min_32_chars_not_pastane_jwt
SUPABASE_ANON_KEY=change_me_run_generate_supabase_secrets_sh
SUPABASE_SERVICE_ROLE_KEY=change_me_run_generate_supabase_secrets_sh
SUPABASE_SECRET_KEY_BASE=change_me_run_generate_supabase_secrets_sh
SUPABASE_VAULT_ENC_KEY=change_me_32_hex_chars_vault_key12
SUPABASE_PG_META_CRYPTO_KEY=change_me_32_hex_meta_key1234
SUPABASE_LOGFLARE_PUBLIC_TOKEN=change_me_logflare_public_token
SUPABASE_LOGFLARE_PRIVATE_TOKEN=change_me_logflare_private_token
SUPABASE_POOLER_TENANT_ID=pastane-prod
SUPABASE_STUDIO_ORG=Pastane
SUPABASE_STUDIO_PROJECT=Production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_strong

# JWT (must match apps/api — uses JWT_SECRET for access token)
JWT_SECRET=change_me_minimum_32_chars_access_secret_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_minimum_32_chars_refresh_secret_prod
JWT_REFRESH_EXPIRES_IN=30d

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin_placeholder
MINIO_SECRET_KEY=change_me_minio_strong
MINIO_BUCKET_PRODUCTS=product-images
MINIO_BUCKET_BANNERS=banners
MINIO_BUCKET_PUBLIC=public
# Optional dedicated public object host. Current production DNS defaults do not assume `storage.azem.cloud`.
# Set both values explicitly if you expose MinIO or object proxy on its own public hostname.
MINIO_PUBLIC_URL=
MINIO_PUBLIC_DOMAIN=

# iyzico Sandbox — web ve mobil aynı sandbox hesabını kullanır
# Sandbox anahtarları: https://sandbox-merchant.iyzipay.com → Ayarlar → API anahtarları
IYZICO_API_KEY=sandbox-tUlcRmrApgH3Hmodsu1gzX92BJsiETJ9
IYZICO_SECRET_KEY=sandbox-4XaoiXcWSgbIPV8RZcndqSAbfkQY20jd
IYZICO_MERCHANT_ID=3427278
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# IYZICO_MOBILE_* boş bırakılırsa yukarıdaki IYZICO_* kullanılır
IYZICO_MOBILE_API_KEY=sandbox-tUlcRmrApgH3Hmodsu1gzX92BJsiETJ9
IYZICO_MOBILE_SECRET_KEY=sandbox-4XaoiXcWSgbIPV8RZcndqSAbfkQY20jd
IYZICO_MOBILE_BASE_URL=https://sandbox-api.iyzipay.com
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=PASTANE
OTP_ACTIVE=false
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@azem.cloud

# Frontends
WEB_URL=https://www.azem.cloud
ADMIN_URL=https://admin.azem.cloud
COURIER_URL=https://courier.azem.cloud

# Production domains
DOMAIN_WEB=www.azem.cloud
DOMAIN_API=api.azem.cloud
DOMAIN_ADMIN=admin.azem.cloud
DOMAIN_COURIER=courier.azem.cloud
DOMAIN_STORAGE=

# Backup (VPS deploy user must be able to write this path)
BACKUP_DIR=/var/www/pastane-app/backups
BACKUP_RETAIN_DAYS=7

# Queue timing
PAYMENT_TIMEOUT_MS=600000
STOCK_RESERVATION_TIMEOUT_MS=600000
# PAYMENT_DEV_AUTO_SUCCESS: ASLA production'da true yapma — API başlangıçta kapanır. Doğrulama: `bash scripts/validate-env.sh .env.production`
PAYMENT_DEV_AUTO_SUCCESS=false

# İyzico mobil checkout tamamlanınca istemci yönlendirmesi için URL şeması (API; varsayılan: pastahane)
MOBILE_PAYMENT_SCHEME=pastahane

# Next.js public (baked at image build time — pass as build-arg in Docker)
NEXT_PUBLIC_SITE_URL=https://www.azem.cloud
