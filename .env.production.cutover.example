# Faz 7 cutover — copy to VPS as .env.production.cutover-draft, review, then apply on maintenance day.
# Merge these DATABASE_URL / DIRECT_URL values into live .env.production when supabase-prod is up.
#
# DO NOT deploy until staging dry-run (Faz 6.8) is green.

# After pg_restore into pastane_supabase_db_prod:
DATABASE_URL=postgresql://pastane_user:YOUR_STRONG_PASSWORD@supabase-db:5432/pastane_db
DIRECT_URL=postgresql://pastane_user:YOUR_STRONG_PASSWORD@supabase-db:5432/pastane_db
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432

# Rollback (legacy postgres profile):
