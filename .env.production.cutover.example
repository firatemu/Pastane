# ARCHIVED — Faz 7 cutover reference only.
# Production defaults are in .env.production.example (supabase-db host).
# Used during one-shot cutover; routine deploy uses merged docker-compose.prod.yml + deploy.sh.
#
# Rollback to legacy postgres: docs/supabase-legacy-rollback-window.md

# After pg_restore into pastane_supabase_db_prod:
DATABASE_URL=postgresql://pastane_user:YOUR_STRONG_PASSWORD@supabase-db:5432/pastane_db
DIRECT_URL=postgresql://pastane_user:YOUR_STRONG_PASSWORD@supabase-db:5432/pastane_db
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432

# Rollback (legacy postgres profile):
# DATABASE_URL=postgresql://pastane_user:YOUR_STRONG_PASSWORD@postgres:5432/pastane_db
# DIRECT_URL=postgresql://pastane_user:YOUR_STRONG_PASSWORD@postgres:5432/pastane_db
# POSTGRES_HOST=postgres
