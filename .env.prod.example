# Production template for azem.cloud — placeholders only.
# Copy to `.env.production` on the VPS and replace every generated secret there.
# Never commit real `.env.production` values.

NODE_ENV=production

# Docker image registry / tag.
# GitHub Actions passes the immutable deploy SHA as IMAGE_TAG at runtime; keep this fallback on the moving main alias.
REGISTRY=ghcr.io/your-github-owner
REGISTRY_SERVER=ghcr.io
REGISTRY_USERNAME=your-github-username
REGISTRY_PASSWORD=change_me_read_packages_token
IMAGE_TAG=main

# Application
API_PORT=3003
# Browser-facing API URL
API_URL=https://api.azem.cloud
PUBLIC_API_URL=https://api.azem.cloud
NEXT_PUBLIC_API_URL=https://api.azem.cloud
CORS_ORIGINS=https://azem.cloud,https://www.azem.cloud,https://admin.azem.cloud,https://courier.azem.cloud
# Server-side Next.js BFF calls inside Docker default to service name:
# WEB_API_URL=http://api:3003
WEB_API_URL=http://api:3003
ADMIN_API_URL=http://api:3003
COURIER_API_URL=http://api:3003
RUNNING_IN_DOCKER=1
SWAGGER_ENABLED=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pastane_db
POSTGRES_USER=pastane_user
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql://pastane_user:change_me_strong@postgres:5432/pastane_db
DIRECT_URL=postgresql://pastane_user:change_me_strong@postgres:5432/pastane_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_strong

# JWT (must match apps/api — uses JWT_SECRET for access token)
JWT_SECRET=change_me_minimum_32_chars_access_secret_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_minimum_32_chars_refresh_secret_prod
JWT_REFRESH_EXPIRES_IN=30d

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin_placeholder
MINIO_SECRET_KEY=change_me_minio_strong
MINIO_BUCKET_PRODUCTS=product-images
MINIO_BUCKET_BANNERS=banners
MINIO_BUCKET_PUBLIC=public
# Public URL for browser-accessible objects (behind Nginx in prod)
MINIO_PUBLIC_URL=https://storage.azem.cloud
MINIO_PUBLIC_DOMAIN=https://storage.azem.cloud

# External services (leave empty until credentials exist)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_MERCHANT_ID=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Mobil checkout (sandbox) — boşsa IYZICO_* devralınır
IYZICO_MOBILE_API_KEY=
IYZICO_MOBILE_SECRET_KEY=
IYZICO_MOBILE_BASE_URL=https://sandbox-api.iyzipay.com
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=PASTANE
OTP_ACTIVE=false
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@azem.cloud

# Frontends
WEB_URL=https://azem.cloud
ADMIN_URL=https://admin.azem.cloud
COURIER_URL=https://courier.azem.cloud

# Production domains
DOMAIN_WEB=azem.cloud
DOMAIN_API=api.azem.cloud
DOMAIN_ADMIN=admin.azem.cloud
DOMAIN_COURIER=courier.azem.cloud
DOMAIN_STORAGE=storage.azem.cloud

# Backup
BACKUP_DIR=/var/backups/pastane
BACKUP_RETAIN_DAYS=7

# Queue timing
PAYMENT_TIMEOUT_MS=600000
STOCK_RESERVATION_TIMEOUT_MS=600000
# Never set PAYMENT_DEV_AUTO_SUCCESS=true in production; the API exits on boot if it is set while NODE_ENV=production.

# Next.js public (baked at image build time — pass as build-arg in Docker)
NEXT_PUBLIC_SITE_URL=https://azem.cloud
