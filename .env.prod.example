# Production template — placeholders only. Copy to `.env.prod` on the server; never commit real secrets.
# For HTTPS + Secure cookies in production builds, use hosts-based staging (see docs/production-deployment-plan.md):
#   https://staging.local (web), https://api.staging.local (API), etc.

NODE_ENV=production

# Docker image registry / tag (semantic version; do not use "latest" as sole prod reference)
REGISTRY=pastane
IMAGE_TAG=v0.0.0-placeholder

# Application
API_PORT=3003
# Browser-facing API URL (use public or staging HTTPS URL when reverse proxy terminates TLS)
API_URL=https://api.staging.local
# Server-side Next.js BFF calls inside Docker default to service name:
# WEB_API_URL=http://api:3003
WEB_API_URL=http://api:3003
ADMIN_API_URL=http://api:3003
COURIER_API_URL=http://api:3003
SWAGGER_ENABLED=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pastane_db
POSTGRES_USER=pastane_user
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql://pastane_user:change_me_strong@postgres:5432/pastane_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_strong

# JWT (must match apps/api — uses JWT_SECRET for access token)
JWT_SECRET=change_me_minimum_32_chars_access_secret_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_minimum_32_chars_refresh_secret_prod
JWT_REFRESH_EXPIRES_IN=30d

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin_placeholder
MINIO_SECRET_KEY=change_me_minio_strong
MINIO_BUCKET_PRODUCTS=product-images
MINIO_BUCKET_BANNERS=banners
MINIO_BUCKET_PUBLIC=public
# Public URL for browser-accessible objects (behind Nginx in prod)
MINIO_PUBLIC_URL=https://storage.staging.local
MINIO_PUBLIC_DOMAIN=https://storage.example.invalid

# External services (leave empty until credentials exist)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=PASTANE
OTP_ACTIVE=false
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.invalid

# Frontends — staging-style hosts for parity testing (replace with real domains at cutover)
WEB_URL=https://staging.local
ADMIN_URL=https://admin.staging.local
COURIER_URL=https://courier.staging.local

# Production domains — not assigned yet; placeholders for future cutover documentation
DOMAIN_WEB=example.invalid
DOMAIN_API=api.example.invalid
DOMAIN_ADMIN=admin.example.invalid
DOMAIN_COURIER=courier.example.invalid
DOMAIN_STORAGE=storage.example.invalid

# Backup
BACKUP_DIR=/var/backups/pastane
BACKUP_RETAIN_DAYS=7

# Queue timing
PAYMENT_TIMEOUT_MS=600000
STOCK_RESERVATION_TIMEOUT_MS=600000
# Never set PAYMENT_DEV_AUTO_SUCCESS=true in production; the API exits on boot if it is set while NODE_ENV=production.

# Next.js public (baked at image build time — pass as build-arg in Docker)
NEXT_PUBLIC_SITE_URL=https://staging.local
