{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspaceFolder}"]
    },
    "git": {
      "command": "bash",
      "args": ["scripts/mcp/git.sh"]
    },
    "postgres": {
      "command": "bash",
      "args": ["scripts/mcp/postgres.sh"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "stitch": {
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${env:STITCH_GOOGLE_API_KEY}"
      }
    },
    "shadcn": {
      "command": "bash",
      "args": ["scripts/mcp/shadcn.sh"]
    }
  }
}
