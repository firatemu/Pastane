# Pastane reverse proxy — HTTP for local and staging-style hosts.
# For production TLS, add ssl_certificate / listen 443 server blocks (see docs/nginx-production-example.md).
#
# /etc/hosts examples:
#   127.0.0.1 staging.local api.staging.local admin.staging.local courier.staging.local storage.staging.local
#
# Upstreams use Docker Compose service names (pastane_edge network).

upstream pastane_web {
  server web:3000;
}
upstream pastane_admin {
  server admin:3001;
}
upstream pastane_courier {
  server courier:3002;
}
upstream pastane_api {
  server api:3003;
}
upstream pastane_minio_s3 {
  server minio:9000;
}

server {
  listen 80;
  server_name staging.local;
  location / {
    proxy_pass http://pastane_web;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
  }
}

server {
  listen 80;
  server_name api.staging.local;
  location / {
    limit_req zone=pastane_api burst=20 nodelay;
    proxy_pass http://pastane_api;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
  }
  location /api/v1/auth/ {
    limit_req zone=pastane_auth burst=5 nodelay;
    proxy_pass http://pastane_api;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
  }
}

server {
  listen 80;
  server_name admin.staging.local;
  location / {
    proxy_pass http://pastane_admin;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
  }
}

server {
  listen 80;
  server_name courier.staging.local;
  location / {
    proxy_pass http://pastane_courier;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
  }
}

server {
  listen 80;
  server_name storage.staging.local;
  location / {
    proxy_pass http://pastane_minio_s3;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering off;
    proxy_request_buffering off;
  }
}

# Convenience for developers hitting nginx without custom hosts (customer web only).
server {
  listen 80 default_server;
  server_name localhost;
  location / {
    proxy_pass http://pastane_web;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
  }
}
