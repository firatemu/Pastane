{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@pastane/tr-api-errors": [
        "../../packages/tr-api-errors/src/index.ts"
      ]
    },
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "incremental": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "isolatedModules": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-ci/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "/tmp/pastane-web-next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
