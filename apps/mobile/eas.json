{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "22.14.0",
      "pnpm": "10.12.1"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_NO_DEPLOY": "1",
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:3003",
        "EXPO_PUBLIC_WEB_URL": "http://10.0.2.2:3000"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_NO_DEPLOY": "1",
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_PUBLIC_API_URL": "https://api.azem.cloud",
        "EXPO_PUBLIC_WEB_URL": "https://azem.cloud",
        "EXPO_PUBLIC_CHECKOUT_DEBUG": "1"
      }
    },
    "production": {
      "extends": "base",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_NO_DEPLOY": "1",
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_PUBLIC_API_URL": "https://api.azem.cloud",
        "EXPO_PUBLIC_WEB_URL": "https://azem.cloud"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-store-service-account.json",
        "track": "internal"
      }
    }
  }
}
