# Application
NODE_ENV=development
API_PORT=3003
API_URL=http://localhost:3003
# URLs returned in JSON for <img src> (banner/product proxy). Browser must reach this host. Docker Compose overrides to localhost for the API service.
PUBLIC_API_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:3003
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Storefront (`apps/web`) server-side fetches: WEB_API_URL ?? API_URL. Docker web service sets WEB_API_URL=http://api:3003 and RUNNING_IN_DOCKER=1 so the hostname `api` resolves inside the container. On the host, use API_URL=http://localhost:3003 and omit WEB_API_URL (or it will fall back when RUNNING_IN_DOCKER is unset).

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pastane_db
POSTGRES_USER=pastane_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://pastane_user:change_me@postgres:5432/pastane_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_minimum_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET_PRODUCTS=product-images
MINIO_BUCKET_BANNERS=banners
MINIO_BUCKET_PUBLIC=public
MINIO_PUBLIC_URL=http://localhost:9000
# Browser must reach this host; objects are stored in MinIO. API applies anonymous s3:GetObject on banner + product image buckets so vitrin/admin <img> URLs work.
MINIO_PUBLIC_DOMAIN=https://storage.pastane.com

# External services
# iyzico Checkout Form: PUBLIC_API_URL + /api/v1/payments/iyzico/form-return must be reachable from iyzico (use a tunnel in local dev unless the API has a public URL). Ödeme sonrası tarayıcı yönlendirmesi için WEB_URL kullanılır.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=PASTANE
OTP_ACTIVE=false
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pastane.com

# Frontends
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
COURIER_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API / docs
SWAGGER_ENABLED=true

# Production domains
DOMAIN_WEB=pastane.com
DOMAIN_API=api.pastane.com
DOMAIN_ADMIN=admin.pastane.com
DOMAIN_COURIER=courier.pastane.com
DOMAIN_STORAGE=storage.pastane.com

# Backup
BACKUP_DIR=/var/backups/pastane
BACKUP_RETAIN_DAYS=7

# Queue timing
PAYMENT_TIMEOUT_MS=600000
STOCK_RESERVATION_TIMEOUT_MS=600000

# When true, POST /payments/initiate immediately completes payment like a successful provider callback (no real card/POS). Only honored when NODE_ENV is not production. Never enable in production Compose or deploy configs; the API refuses to start if this is true while NODE_ENV=production. Put this in repo-root `.env` or `apps/api/.env` and restart the API process so Nest loads it (or rely on Compose `env_file` injecting into the container).
PAYMENT_DEV_AUTO_SUCCESS=false

# Google Stitch MCP (Cursor remote server — set in shell env or repo-root .env for ${env:STITCH_GOOG_API_KEY})
STITCH_GOOG_API_KEY=
