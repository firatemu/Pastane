{
  "name": "pastane-platform",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web-apps": "turbo run dev --filter=@pastane/web --filter=@pastane/admin --filter=@pastane/courier",
    "dev:web-apps-host": "bash -lc 'pnpm --filter @pastane/web dev & pnpm --filter @pastane/admin dev:host & pnpm --filter @pastane/courier dev:host & wait'",
    "build": "pnpm prisma:generate && turbo run build",
    "build:ci": "pnpm prisma:generate && NEXT_DIST_DIR=.next-ci turbo run build",
    "lint": "turbo run lint",
    "typecheck": "pnpm prisma:generate && turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build:ci",
    "test:all": "pnpm test",
    "build:all": "pnpm build",
    "doctor": "tsx --tsconfig scripts/tsconfig.json scripts/doctor/index.ts",
    "doctor:core": "tsx --tsconfig scripts/tsconfig.json scripts/doctor/index.ts core",
    "doctor:api": "tsx --tsconfig scripts/tsconfig.json scripts/doctor/index.ts api",
    "doctor:mobile": "tsx --tsconfig scripts/tsconfig.json scripts/doctor/index.ts mobile",
    "doctor:frontend": "tsx --tsconfig scripts/tsconfig.json scripts/doctor/index.ts frontend",
    "e2e": "bash scripts/ci-e2e.sh",
    "e2e:smoke": "pnpm --filter @pastane/web-e2e run e2e:smoke && pnpm --filter @pastane/admin-e2e run e2e:smoke && pnpm --filter @pastane/courier-e2e run e2e:smoke",
    "e2e:runner": "turbo run e2e",
    "docker:dev:up": "docker compose --env-file .env -f docker/docker-compose.dev.yml up -d",
    "docker:dev:up-exclusive": "bash scripts/docker-stop-local-prod.sh && docker compose --env-file .env -f docker/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose --env-file .env -f docker/docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose --env-file .env -f docker/docker-compose.dev.yml logs -f",
    "docker:dev:rebuild-api": "bash scripts/docker-rebuild-api.sh",
    "deploy:help": "echo 'Bkz. docs/DEPLOYMENT_WORKFLOW.md ve docs/ROLLBACK_GUIDE.md'",
    "push:vps": "bash scripts/push-vps.sh",
    "push:vps:fast": "bash scripts/push-vps.sh --skip-checks",
    "deploy:prod": "tsx --tsconfig scripts/tsconfig.json scripts/deploy/deploy-prod.ts",
    "deploy:rollback": "tsx --tsconfig scripts/tsconfig.json scripts/deploy/rollback.ts",
    "health:check": "tsx --tsconfig scripts/tsconfig.json scripts/deploy/health-check.ts",
    "verify:vps": "tsx --tsconfig scripts/tsconfig.json scripts/deploy/verify-vps.ts",
    "git:validate": "tsx --tsconfig scripts/tsconfig.json scripts/git/validate.ts",
    "git:push-deploy": "pnpm doctor:core && pnpm check && bash scripts/push-vps.sh",
    "repo:status": "bash scripts/repo-status.sh",
    "verify:structure": "bash scripts/verify-structure.sh",
    "verify:docker-lockfile": "bash scripts/verify-docker-lockfile.sh",
    "fix:next-perms": "bash scripts/fix-next-perms.sh",
    "fix:frontend-cache": "bash scripts/fix-frontend-next-cache.sh",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "staging:supabase:up": "docker compose --project-name supabase-staging --env-file .env.staging -f docker/docker-compose.supabase.staging.yml up -d",
    "staging:supabase:down": "docker compose --project-name supabase-staging --env-file .env.staging -f docker/docker-compose.supabase.staging.yml down",
    "staging:app:up": "docker compose --project-name pastane-staging --env-file .env.staging -f docker/docker-compose.staging.yml up -d",
    "staging:app:down": "docker compose --project-name pastane-staging --env-file .env.staging -f docker/docker-compose.staging.yml down",
    "staging:dry-run": "bash scripts/staging/run-staging-dry-run.sh",
    "staging:smoke": "bash scripts/staging/smoke-staging.sh",
    "staging:supabase:prod:config": "docker compose --project-name supabase-prod --env-file .env.production -f docker/docker-compose.supabase.prod.yml config",
    "prisma:generate": "pnpm --filter @pastane/database prisma:generate",
    "build:web": "pnpm prisma:generate && turbo run build --filter=@pastane/web",
    "build:web:clean": "bash scripts/web-build-clean.sh",
    "mobile:start": "pnpm --filter @pastane/mobile start",
    "mobile:android": "pnpm --filter @pastane/mobile android",
    "mobile:typecheck": "pnpm --filter @pastane/mobile typecheck",
    "mobile:build:android": "pnpm --filter @pastane/mobile build:android",
    "mobile:build:android:apk": "pnpm --filter @pastane/mobile build:android:apk",
    "mobile:sync-check": "tsx --tsconfig scripts/tsconfig.json scripts/mobile/sync-check.ts",
    "mobile:openapi-export": "tsx --tsconfig scripts/tsconfig.json scripts/mobile/export-openapi.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@nestjs/cli": "^11.0.21",
    "eslint": "^9.26.0",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "supabase": "^2.101.0",
    "tsx": "^4.22.1",
    "turbo": "^2.9.14",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
