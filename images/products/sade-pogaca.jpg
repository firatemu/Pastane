    #uc_fullscreen_navigation_menu_elementor_3d228b2 .ue_hamburger > div {
      position: relative;
      -webkit-box-flex: 0;
              flex: none;
      width: 100%;
      height: 2px;
      transition: all 0.4s ease;
      display: flex;
              align-items: center;
