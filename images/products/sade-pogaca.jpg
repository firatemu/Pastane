<!--   Unlimited Elements 2.0.10 Scripts --> 
<script type='text/javascript' id='unlimited-elements-scripts'>

/* Fullscreen Menu scripts: */ 

jQuery(document).ready(function(){
function uc_fullscreen_navigation_menu_elementor_3d228b2_start(){
			
		
 	var objWidget = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2");
	var objCheckbox = objWidget.find(".checkbox-toggle");
  	var objInputWrapper = objWidget.find(".ue-input-wrapper-align");
	var classActive = "is-active";
	var objAnimatedHamburger = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2 .uc_hamburger");
    var objAnimatedHamburgerLink = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2 .uc_animated_hamburger_icon"); 
  
  	var menuOpenedClass = "menu-opened";
  
	if (objCheckbox.is(":checked"))
    objCheckbox.removeAttr("checked");
          
    objCheckbox.prop('checked',false);
    objWidget.removeClass(menuOpenedClass);
	
	var objLinks = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2 .uc-list-menu a");
  	var objBody = jQuery("body.elementor-page");
  	var objHTML = jQuery("html");
 
  
  	objWidget.delegate(".checkbox-toggle", "click", function(){
  
      if(objCheckbox.is(":checked")){
        objBody.addClass(menuOpenedClass);
        objHTML.addClass(menuOpenedClass);
        objWidget.addClass(menuOpenedClass);
        objMenu.collapseAll();
        objMenu.openCurrentPageMenuItem();        
        objLinks.each(function(){
          var objLink = jQuery(this);
          toggleIcon(objLink);
        });
                                                                                               
        if(objAnimatedHamburger && objAnimatedHamburger.length > 0){
          objAnimatedHamburger.addClass(classActive);
     	  objAnimatedHamburgerLink.addClass(classActive);
        }                                                                                       
                
      }else{
      	objBody.removeClass(menuOpenedClass);
        objHTML.removeClass(menuOpenedClass);
        objWidget.removeClass(menuOpenedClass);
        
        if(objAnimatedHamburger && objAnimatedHamburger.length > 0){
          objAnimatedHamburger.removeClass(classActive);
     	  objAnimatedHamburgerLink.removeClass(classActive);
        }
        
      }            
    });
  
function toggleIcons() {
    var objLinks = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2 .uc-list-menu a");
    var objMenu = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2");
    var objExpandIcon = objMenu.find(".ue_inner_menu_expand_icon").html();
    var objCollapseIcon = objMenu.find(".ue_inner_menu_collapse_icon").html();

    objLinks.each(function() {
        var objLink = jQuery(this);
        var isLinkOpened = objLink.hasClass('expanded');
        var objLinkContainer = objLink.find('.uc-menu-item-pointer');

        // Update icon based on the state of the menu item
        if (isLinkOpened) {
            objLinkContainer.html(objCollapseIcon);
        } else {
            objLinkContainer.html(objExpandIcon);
        }
    });
}
  
function toggleIcon(objLink) {
    var isLinkOpened = objLink.hasClass('expanded');
    var objLinkContainer = objLink.find('.uc-menu-item-pointer');
    var objMenu = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2");
    var objExpandIcon = objMenu.find(".ue_inner_menu_expand_icon").html();
    var objCollapseIcon = objMenu.find(".ue_inner_menu_collapse_icon").html();

    // Update icon based on the state of the menu item
    if (isLinkOpened) {
        objLinkContainer.html(objCollapseIcon);
    } else {
        objLinkContainer.html(objExpandIcon);
    }

    // Update all icons
    toggleIcons();
}

	
  	jQuery(window).on("keydown", function(e) {
        if(e.key == "Escape"){
           if (objCheckbox.is(":checked"))
            objCheckbox.removeAttr("checked");

            objCheckbox.prop('checked',false); 
          	objWidget.removeClass(menuOpenedClass);
          
            objHTML.removeClass(menuOpenedClass);
        } 
	});
  
  	//imitate top position of the close icon
    	
  
    if(typeof UCFullscreenMenu == "undefined")
    console.log("fullscreen menu error: the fullscreen file: menu.js in ac_assets folder is missing or empty, please check");
    
    var objMenu = new UCFullscreenMenu("uc_fullscreen_navigation_menu_elementor_3d228b2 .ue_inner_menu");
    objMenu.runMenu();     
     
    objLinks.click(function(e){      
		var objLink = jQuery(this);
      
      	toggleIcon(objLink);
        
		var url = objLink.attr("href");
		url = jQuery.trim(url);
		
		if(!url)
			return(true);
      
      	var objLinkParent = objLink.parent();
      	var isClickable = jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2 .ue_inner_menu").data('clickable');
      
      	function goToItem(){        	
              if (objCheckbox.is(":checked"))
              objCheckbox.removeAttr("checked");

              objCheckbox.prop('checked',false);
              objWidget.removeClass(menuOpenedClass);
            

          	  objBody.removeClass(menuOpenedClass);
          	  objHTML.removeClass(menuOpenedClass);
        }
      
      	var expandCollapsed = jQuery('.uc-menu-item-pointer');
      	var target = e.target
        
        if(expandCollapsed && expandCollapsed.length > 0 && target.className == expandCollapsed[0].className)
        return(true);
      
      	if(isClickable == false){
          
          if(objLinkParent.hasClass('menu-item-has-children'))
          return(true)
          else
          goToItem();          
          
        }else{
          goToItem();
        }
      
		return(true);
	});
     
          
        
      objLinks.each(function(){
         objLink = jQuery(this);
         toggleIcon(objLink);
      }); 
     
      
       
    /**
    * fix for sticky parent section
    */
    function initFixForStickyParent(){
    	var objParents = objWidget.parents();
        var objStikyParent;
      
      	objParents.each(function(){
        	var objParent = jQuery(this); 
          
          	if(objParent.hasClass("elementor-sticky") == true){
            	var isParentVisible = objParent.is(":visible");
              
              	if(isParentVisible == true){
                  objParent.addClass("uc-visible")
                  objParent.removeClass("uc-hidden")
                } else{
                  objParent.addClass("uc-hidden")
                  objParent.removeClass("uc-visible")
                }
                  
            }	
              
        });
    }
     
    //init fix for sticky
    setTimeout(initFixForStickyParent,300);
     
    jQuery(window).on("scroll", function(){
     	//init fix for sticky
    	setTimeout(initFixForStickyParent,100);
    });
  
    // Fix: safari browser fullscrenn menu not displayed correctly
    jQuery(document).ready(function() {
      var isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
      if (isSafari) {
        jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2").closest(".e-flex.e-con-boxed.e-con.e-parent").css("overflow", "visible");
      }
    });
    	
}if(jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2").length && !jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2").parents('[data-elementor-type="popup"]').length) uc_fullscreen_navigation_menu_elementor_3d228b2_start();
	jQuery( document ).on( 'elementor/popup/show', (event, id, objPopup) => {
	if(objPopup.$element.has(jQuery("#uc_fullscreen_navigation_menu_elementor_3d228b2")).length) uc_fullscreen_navigation_menu_elementor_3d228b2_start()});
});
			
</script>
		<script type="text/template" id="tmpl-convertkit-quicktags-modal">
			<div id="convertkit-quicktags-modal">
				<div class="media-frame-title"><h1></h1></div>
				<div class="media-frame-content"></div>
				<div class="media-frame-toolbar">
					<div class="media-toolbar">
						<div class="media-toolbar-secondary">
							<button type="button" class="button button-large cancel">Cancel</button>
						</div>
						<div class="media-toolbar-primary">
							<button type="button" class="button button-primary button-large">Insert</button>
						</div>
					</div>
				</div>
			</div>
		</script>
		<script>
(function () {
  function openChatGPTWithPrompt(prompt) {
    var base = "https://chatgpt.com/?q=";
    var link = base + encodeURIComponent(prompt);
    window.open(link, "_blank", "noopener,noreferrer");
  }

  function currentPageUrl() {
    return window.location.href.split("#")[0];
  }

  function buildPrompt(type) {
    var url = currentPageUrl();

    if (type === "summary") {
      return (
        "Please read this article: " + url + "\n\n" +
        "Summarise the key points in 5 bullet points or fewer for a home cook.\n" +
        "Then add one short 'What to do next' tip (1 sentence).\n" +
        "When you mention a factual point, cite the article as the source and include the link to vidarbergum.com."
      );
    }

    if (type === "substitutions") {
      return (
        "Use this recipe: " + url + "\n" +
        "Also check: https://vidarbergum.com/article/turkish-middle-eastern-ingredients/\n\n" +
        "Scan headnote + recipe + ingredients resource for substitutions Vidar Bergum already mentions. For each ingredient, list those first as 'Vidar’s suggestion'.\n" +
        "Present substitutions only for hard-to-find ingredients (skip basic staples).\n" +
        "For each ingredient, list Vidar’s suggestion from headnotes, recipe or ingredients resource (if any) first, then add additional suggestions (use headline Other options). For both, include any key adjustment. If Vidar suggests the ingredient is essential, note this.\n" +
        "Keep it as authentic as possible for Turkish and Middle Eastern cooking.\n" +
        "Cite the URL for the source (recipe, ingredients resource or other).\n" +
        "Finish by asking if I want to (1) substitute any other ingredients, (2) get a response better tailored to where I live or (3) look for more similar recipes by Vidar."
      );
    }

    if (type === "allergy") {
      return (
        "Recipe: " + url + "\n\n" +
        "Also check: https://vidarbergum.com/article/turkish-middle-eastern-ingredients/\n\n" +
        "Ask me (and wait): Which allergy or restriction should I adapt this for, and where do I live (country and city)? Answering the restriction is essential, but don't ask again if I skip country or city.\n\n" +
        "After I reply: give ingredient swaps (for the restricted ingredients only), method changes, 1-sentence result note, and cross-contamination notes if relevant. Label clearly whether suggestions are mentioned by Vidar or not.\n" +
        "Show this disclaimer first: General suggestions only. Allergy needs and labelling rules vary. Cross-check with local medical advice and a recognised allergy organisation, and always read labels.\n\n" +
        "Show this disclaimer after giving the reply: Verify with local guidance. Deviations from the recipe, including substitutions, may significantly affect how the dish turns out.\n" +
        "Finish by asking if I want to explore similar recipes that are naturally in line with my diet. Browse Vidar's website first, and give one option for an alternative recipe from a website with authority in that allergy or diet field that is a close match with the original recipe above.\n" +
        "Cite the recipe URL as the source."
      );
    }

    if (type === "shopping") {
      return (
        "Use this recipe as the reference: " + url + "\n\n" +
        "First, ask me where I live (city + country) and where I usually shop for groceries, so you can tailor the shopping list to my circumstances. Also ask me to tell you if I plan to make a different serving size than specified in the recipe.\n\n" +
        "After I reply, create a shopping list tailored to my location and preferred shop as much as possible:\n" +
        "- Use the recipe’s ingredient amounts, scaled to the servings I specify (otherwise use the recipe’s default).\n" +
        "- Round up small quantities to realistic purchase units where appropriate, and show how much the recipe actually needs in brackets, for example: 1 cucumber (you need 1/2 cucumber).\n" +
        "- If an ingredient is given by weight, specify both the weight I need for the recipe and the likely package size I need to look for (browse the supermarket’s website if possible).\n\n" +
        "Structure the list by supermarket sections, for example:\n" +
        "Produce, Herbs & greens, Meat & fish, Dairy & eggs, Bakery, Pantry, Spices, Canned & jars, Frozen, Drinks, Other.\n\n" +
        "End by asking: Let me know if you want me to suggest shops in your local area for harder to find ingredients.\n\n" +
        "Finally, include the recipe link on vidarbergum.com for my convenience (the same URL you used as the reference)."
      );
    }

    return "";
  }

  // Event delegation: works even if Elementor re-renders HTML
  document.addEventListener("click", function (e) {
    var a = e.target.closest("a");
    if (!a) return;

    var href = a.getAttribute("href") || "";

    if (href === "#ai-summary") {
      e.preventDefault();
      openChatGPTWithPrompt(buildPrompt("summary"));
      return;
    }

    if (href === "#ai-substitutions") {
      e.preventDefault();
      openChatGPTWithPrompt(buildPrompt("substitutions"));
      return;
    }

    if (href === "#ai-allergy") {
      e.preventDefault();
      openChatGPTWithPrompt(buildPrompt("allergy"));
      return;
    }

    if (href === "#ai-shopping") {
      e.preventDefault();
      openChatGPTWithPrompt(buildPrompt("shopping"));
      return;
    }
  });
})();
</script>
