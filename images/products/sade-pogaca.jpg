  transition: 0.4s;
  backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  position:absolute;
  z-index:99999999;
}


      #uc_fullscreen_navigation_menu_elementor_3d228b2 .checkbox-toggle:checked + .ue_hamburger > div {
