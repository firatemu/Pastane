    #uc_fullscreen_navigation_menu_elementor_3d228b2 .ue_hamburger > div:before,
    #uc_fullscreen_navigation_menu_elementor_3d228b2 .ue_hamburger > div:after {
      content: '';
      position: absolute;
      z-index: 1;
      top: -10px;
      left: 0;
      width: 100%;
      height: 2px;
