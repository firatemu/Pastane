  text-transform:uppercase !important;
}

.wprm-recipe-details-unit {
  margin-left:3px;
}

.wprm-recipe-icon {
  margin-right:5px;
}

.inheader .wprm-recipe-rating {
  text-align:left !important;
}




.wprm-recipe-template-recipes-2025-cutout-template-header {
  top:25px;
}

.wprm-recipe-text-header {
  display:block;
}

