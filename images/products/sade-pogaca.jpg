    #uc_fullscreen_navigation_menu_elementor_3d228b2 .checkbox-toggle:checked + .ue_hamburger > div:before,
    #uc_fullscreen_navigation_menu_elementor_3d228b2 .checkbox-toggle:checked + .ue_hamburger > div:after {
