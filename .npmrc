# Align with `Dockerfile.dev` (`pnpm install --shamefully-hoist`) and avoid broken per-package
# `apps/*/node_modules` symlinks pointing at stale `.pnpm/...` paths after linker / major pnpm bumps.
#
# Repo also sets `nodeLinker: hoisted` in `pnpm-workspace.yaml`; `shamefully-hoist` keeps the root
# `node_modules/next` layout consistent so internal files like `dist/shared/lib/segment.js` resolve
# (fixes `Cannot find module '../../segment'` during `next build` / Docker dev).
shamefully-hoist=true
