# Staging dry-run (Faz 6.8) — copy on VPS: cp .env.staging.example .env.staging && chmod 600 .env.staging
# NEVER use production secrets. NEVER point at production postgres/redis/minio volumes.
# Access via loopback only (SSH tunnel): api :3103, web :3100, admin :3101, courier :3102

NODE_ENV=production
REGISTRY=pastane
IMAGE_TAG=staging-dry-run

# Staging loopback URLs (no public DNS — do not change azem.cloud nginx)
API_PORT=3003
API_URL=http://127.0.0.1:3103
PUBLIC_API_URL=http://127.0.0.1:3103
NEXT_PUBLIC_API_URL=http://127.0.0.1:3103
CORS_ORIGINS=http://127.0.0.1:3100,http://127.0.0.1:3101,http://127.0.0.1:3102
WEB_API_URL=http://api:3003
ADMIN_API_URL=http://api:3003
COURIER_API_URL=http://api:3003
RUNNING_IN_DOCKER=1
SWAGGER_ENABLED=true

# Staging Supabase DB (docker-compose.supabase.staging.yml)
STAGING_POSTGRES_DB=pastane_db_staging
STAGING_POSTGRES_USER=pastane_staging_user
STAGING_POSTGRES_PASSWORD=change_me_staging_db_strong
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_DB=pastane_db_staging
POSTGRES_USER=pastane_staging_user
POSTGRES_PASSWORD=change_me_staging_db_strong
DATABASE_URL=postgresql://pastane_staging_user:change_me_staging_db_strong@supabase-db:5432/pastane_db_staging
DIRECT_URL=postgresql://pastane_staging_user:change_me_staging_db_strong@supabase-db:5432/pastane_db_staging

# Staging Redis (isolated volume)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_staging_redis_strong

# Staging JWT — MUST differ from production
JWT_SECRET=change_me_staging_jwt_access_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_staging_jwt_refresh_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Staging MinIO (isolated volume, loopback 9100)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=staging_minio_access
MINIO_SECRET_KEY=change_me_staging_minio_strong
MINIO_BUCKET_PRODUCTS=product-images-staging
MINIO_BUCKET_BANNERS=banners-staging
MINIO_BUCKET_PUBLIC=public-staging
MINIO_PUBLIC_URL=http://127.0.0.1:9100
MINIO_PUBLIC_DOMAIN=http://127.0.0.1:9100

# İyzico SANDBOX only for staging
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=PASTANE
OTP_ACTIVE=false

WEB_URL=http://127.0.0.1:3100
ADMIN_URL=http://127.0.0.1:3101
COURIER_URL=http://127.0.0.1:3102
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3100

BACKUP_DIR=/var/backups/pastane-staging
BACKUP_RETAIN_DAYS=3
PAYMENT_TIMEOUT_MS=600000
STOCK_RESERVATION_TIMEOUT_MS=600000
# Staging may use auto-success for checkout dry-run (NODE_ENV=production blocks it — use staging API flag via separate build or test with sandbox)
PAYMENT_DEV_AUTO_SUCCESS=false

# Optional pgAdmin profile (docker-compose.supabase.staging.yml --profile studio)
STAGING_PGADMIN_EMAIL=staging-admin@example.test
STAGING_PGADMIN_PASSWORD=change_me_staging_pgadmin

# Dry-run artifacts — VPS: /var/backups/pastane-staging | local WSL: tmp/pastane-staging
BACKUP_DIR=/var/backups/pastane-staging
STAGING_TIMING_REPORT=/var/backups/pastane-staging/cutover-timing-report.json
