# Full deploy (./scripts/deploy-vps.sh without --push-only): VPS_HOST is required.
# Use --push-only if only GitHub Actions should SSH to the server.

# Copy next to deploy script secrets (do not commit real values):
#
#   cp scripts/deploy-vps.env.example scripts/deploy-vps.env.local
#   chmod 600 scripts/deploy-vps.env.local
#
# REQUIRED for deploy-vps.sh / pnpm push:vps — edit .env.local: put your real IP or DNS (not YOUR_VPS_IP):

VPS_HOST=YOUR_VPS_IP

# VPS_USER=deploy
# VPS_PORT=22
# VPS_APP_DIR=/var/www/pastane-app/app
#
# Optional: non-default SSH private key path (otherwise ssh uses your normal agent/config).
# VPS_SSH_IDENTITY=~/.ssh/id_ed25519_pastane
#
# Optional: branch pushed before remote deploy (default: main).
# VPS_DEPLOY_BRANCH=main
#
# `pnpm push:vps`: yalnızca VPS `./deploy.sh` güncellenir — geliştiricide prod Docker tetiklenmez.

