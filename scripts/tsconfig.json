{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false,
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true
  },
  "include": ["lib/**/*.ts", "doctor/**/*.ts", "deploy/**/*.ts", "mobile/**/*.ts", "git/**/*.ts"]
}
